# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (public — safe in browser when RLS is configured correctly)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (SECRET — server only, never expose to client)
STRIPE_SECRET_KEY=sk_test_or_sk_live_xxx

# Base URL used for Stripe redirects
NEXT_PUBLIC_BASE_URL=https://izpiti.pro
